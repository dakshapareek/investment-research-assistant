# ===========================================
# INVESTMENT RESEARCH ASSISTANT - API KEYS
# ===========================================
# Copy this file to .env and add your actual API keys

# LLM APIs (Choose one or more for sentiment analysis)
# ---------------------------------------------
# Google Gemini (Recommended - Free tier available, 60 req/min)
# Get key: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI GPT-4 (Best accuracy, paid)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (Alternative to OpenAI)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Social Media APIs
# ---------------------------------------------
# Reddit API (Required for social sentiment)
# 1. Go to: https://www.reddit.com/prefs/apps
# 2. Click "Create App" or "Create Another App"
# 3. Select "script" type
# 4. Copy client ID and secret
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=InvestmentResearch/1.0

# Twitter/X API v2 (Optional)
# Get key: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret

# Financial Data APIs
# ---------------------------------------------
# Financial Modeling Prep (Recommended - 250 requests/day free)
# Get key: https://site.financialmodelingprep.com/developer/docs/
FINANCIAL_MODELING_PREP_API_KEY=your_fmp_api_key

# Alpha Vantage (25 requests/day free, real-time data)
# Get key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Finnhub (Free tier: 60 calls/minute)
# Get key: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key

# Polygon.io (Free tier available)
# Get key: https://polygon.io/dashboard/signup
POLYGON_API_KEY=your_polygon_key

# Marketstack (100 requests/month free)
# Get key: https://marketstack.com/signup/free
MARKETSTACK_API_KEY=your_marketstack_key

# EODHD (20 requests/day free)
# Get key: https://eodhistoricaldata.com/register
EODHD_API_KEY=your_eodhd_key

# News APIs
# ---------------------------------------------
# NewsAPI.org (Free tier: 100 requests/day)
# Get key: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key

# Benzinga (Premium)
BENZINGA_API_KEY=your_benzinga_key

# Government Data APIs
# ---------------------------------------------
# BLS API (Optional - public access available, key for higher limits)
# Get key: https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here

# FRED API (Federal Reserve Economic Data)
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# Email Configuration (Gmail)
# ---------------------------------------------
# To send investment reports via email:
# 1. Use your Gmail address
# 2. Generate an App Password (NOT your regular Gmail password):
#    - Go to: https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Other (Custom name)"
#    - Copy the 16-character password
# 3. Add credentials below
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# MCP (Model Context Protocol) Configuration
# ---------------------------------------------
# Enable MCP for financial data (true/false)
USE_MCP_FOR_FINANCIAL_DATA=true

# MCP Server Command (full path to uvx.exe)
# Windows: C:\Users\YourName\.local\bin\uvx.exe
# Mac/Linux: /Users/YourName/.local/bin/uvx
MCP_SERVER_COMMAND=uvx

# MCP Server to use with arguments
# Options: mcp-server-fetch, mcp-server-yahoo-finance, mcp-server-alpha-vantage
MCP_SERVER_ARGS=mcp-server-fetch,--ignore-robots-txt
